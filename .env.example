# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Role IDs (integers)
ROLE_APPROVED=000000000000000000
ROLE_VISITOR=000000000000000000
ROLE_UNVERIFIED=000000000000000000

# Channel IDs
MODMAIL_CATEGORY_ID=000000000000000000   # Category where thread channels are created
MOD_LOG_CHANNEL_ID=000000000000000000   # Channel for AI decision notifications

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://modmail:secret@localhost:5432/modmail

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI ─────────────────────────────────────────────────────────────────────────
# Provider: "anthropic" | "openai" | "mock"
LLM_PROVIDER=mock

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model to use (provider-specific)
LLM_MODEL=claude-sonnet-4-20250514   # or gpt-4o

# Confidence thresholds for auto-execution (0.0 – 1.0)
CONFIDENCE_APPROVE=0.80
CONFIDENCE_VISITOR=0.50
CONFIDENCE_REJECT=0.75

# Max LLM retries before falling back to human review
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# Max follow-up question rounds before forcing human review
MAX_QUESTION_ROUNDS=3

# ── App ─────────────────────────────────────────────────────────────────────────
ENV=development        # development | production
LOG_LEVEL=INFO

# Brief description of your server, injected into AI prompts
SERVER_CONTEXT=A community Discord server focused on [your topic].
